# ── MODE ──────────────────────────────────────────────────────────────────────
# true  → notify Telegram only, no orders placed (no Polymarket keys needed)
# false → live trading, places real orders on Polymarket
DRY_RUN=true

# ── COPY TARGETS ──────────────────────────────────────────────────────────────
# Comma-separated Polygon wallet addresses to copy-trade
TARGET_WALLETS=0xce25e214d5cfe4f459cf67f08df581885aae7fdc

# ── COPY SIZING ───────────────────────────────────────────────────────────────
COPY_STRATEGY=proportional   # exact | proportional
COPY_RATIO=0.1               # multiplier when proportional (0.01–1.0)
MAX_NOTIONAL_PER_TRADE=50    # max USDC per single copied trade
MAX_MARKET_EXPOSURE=500      # max USDC allocated to one market
MAX_SESSION_NOTIONAL=2000    # max USDC total per session
MAX_DRAWDOWN_PCT=15          # halt trading if drawdown exceeds this %

# ── NOTIFICATIONS ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # from @BotFather
TELEGRAM_CHAT_ID=            # your chat/group ID
SLACK_WEBHOOK_URL=           # optional Slack webhook

# ── LIVE TRADING ONLY (DRY_RUN=false) ────────────────────────────────────────
# Derive these once by running: yarn derive-key
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
PRIVATE_KEY=                 # 0x-prefixed Polygon wallet private key
FUNDER_ADDRESS=              # optional: proxy wallet address

# ── MISC ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info               # trace | debug | info | warn | error
